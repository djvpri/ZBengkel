# ============================================================
# BENGKEL POS — Environment Variables
# Copy file ini menjadi .env dan isi nilainya
# ============================================================

# Database PostgreSQL (Railway otomatis mengisi ini)
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# NextAuth — wajib diisi dengan string acak minimal 32 karakter
NEXTAUTH_SECRET="ganti-dengan-string-rahasia-minimal-32-karakter"
NEXTAUTH_URL="https://domain-railway-kamu.up.railway.app"

# ============================================================
# OPSIONAL — WhatsApp Notifikasi Stok (via Fonnte)
# Daftar di: https://fonnte.com
# ============================================================
FONNTE_TOKEN=""
WA_ADMIN_NUMBER="628xxxxxxxxxx"   # Format internasional tanpa +

# ============================================================
# OPSIONAL — Info Bengkel (tampil di struk PDF)
# ============================================================
NEXT_PUBLIC_BENGKEL_NAMA="Bengkel Makmur Jaya"
NEXT_PUBLIC_BENGKEL_ALAMAT="Jl. Contoh No. 1, Pontianak"
NEXT_PUBLIC_BENGKEL_TELP="0561-XXXXXX"
